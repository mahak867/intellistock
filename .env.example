# ─────────────────────────────────────────────────────────────────────────────
# IntelliStock — Environment Variables
# Copy this to .env and fill in all values marked REQUIRED
# NEVER commit .env to version control
# ─────────────────────────────────────────────────────────────────────────────

# ── App ────────────────────────────────────────────────────────────────────────
APP_NAME=IntelliStock
APP_VERSION=1.0.0
ENVIRONMENT=development          # development | staging | production
DEBUG=true
LOG_LEVEL=INFO

# ── Security (REQUIRED) ────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_a_strong_secret_key_minimum_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (use * for dev only)
ALLOWED_ORIGINS=http://localhost:8501,http://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ── Database (PostgreSQL) (REQUIRED) ──────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://intellistock:CHANGE_ME_DB_PASSWORD@localhost:5432/intellistock
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30

# Docker Compose variable (separate from DATABASE_URL)
POSTGRES_USER=intellistock
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD

# ── Redis (REQUIRED) ───────────────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@localhost:6379/0
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
CACHE_TTL_SECONDS=300
PREDICTION_CACHE_TTL=900

# ── ML Model ───────────────────────────────────────────────────────────────────
MODEL_STORE=local                # local | s3 | gcs | azure
MODEL_BUCKET=intellistock-models
MODEL_VERSION=v1
SEQUENCE_LENGTH=60
PREDICTION_HORIZON=5
RETRAIN_INTERVAL_HOURS=24

# ── AWS (if MODEL_STORE=s3) ────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1

# ── GCP (if MODEL_STORE=gcs) ──────────────────────────────────────────────────
GCP_PROJECT_ID=
GCP_SERVICE_ACCOUNT_KEY=

# ── Azure (if MODEL_STORE=azure) ───────────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=

# ── Monitoring ─────────────────────────────────────────────────────────────────
SENTRY_DSN=                      # get from sentry.io (leave empty to disable)
PROMETHEUS_ENABLED=true
OTEL_EXPORTER_ENDPOINT=          # e.g. http://jaeger:4317

# ── Market Data ────────────────────────────────────────────────────────────────
DEFAULT_EXCHANGE=NSE
DEFAULT_CURRENCY=INR
MARKET_DATA_LOOKBACK_YEARS=5
YFINANCE_TIMEOUT=30

# ── Dashboard ──────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
